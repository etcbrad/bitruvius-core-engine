                        key={`ring-${idx}`}
                        cx={characterCenterX}
                        cy={characterCenterY}
                        r={r}
                        fill="none"
                        stroke="#006400"
                        strokeWidth={idx % 2 === 0 ? 2 : 1}
                        opacity={0.75}
                      />
                    );
